# ============================================
# 文字之境 - 后台管理服务环境变量配置
# ============================================
# 服务器配置
# ============================================
PORT=8001
NODE_ENV=development

# ============================================
# 数据库配置 (必填)
# ============================================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=toefl_user
DB_PASSWORD=mojz168168
DB_NAME=ai_xsread

# ============================================
# JWT配置 (必填 - 已生成强随机密钥)
# ============================================
JWT_SECRET=c9f5e2d8a3b6f1e4d7c2b9f6a5e3d1c8b4f7a2e6d9c3b5f8a1e4d7c2b6f9a3e5
JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# CORS配置
# 多个域名用逗号分隔
# ============================================
CORS_ORIGIN=http://localhost:3010,http://127.0.0.1:3010

# ============================================
# 文件上传配置
# ============================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=2097152

# ===== 日志配置 =====
LOG_LEVEL=info

# ===== 安全提示 =====
# ⚠️ 生产环境必须修改:
# 1. DB_PASSWORD - 使用强密码
# 2. JWT_SECRET - 重新生成新的密钥
# 3. NODE_ENV - 设置为 production
# 4. CORS_ORIGIN - 配置实际的前端域名

# ============================================
# 激活码加密密钥（必须与 backend 一致）
# 用 SHA-256(secret + ":activation-code") 派生 AES-256 密钥
# ============================================
ACTIVATION_CODE_SECRET=1da1ebfa8bab228b6198f38900f11eacf5b3087cc34840fe22ce85c9be30059a7d1461df7513e96fcd7b12755afa2b99
