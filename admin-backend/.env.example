# ============================================
# MOMO小说 - 后台管理服务环境变量配置示例
# ============================================
# 
# 使用说明:
# 1. 复制此文件为 .env
# 2. 修改所有配置项为实际值
# 3. 确保 .env 文件已添加到 .gitignore
# 4. 生产环境必须使用强密码和密钥
#
# ============================================

# ============================================
# 服务器配置
# ============================================
PORT=8001
NODE_ENV=development

# ============================================
# 数据库配置 (必填)
# ============================================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your_database_user
DB_PASSWORD=your_secure_database_password_here
# 数据库名（可选别名 DB_DATABASE，与用户后端 backend/.env 保持一致即可）
DB_NAME=ai_xsread

# ============================================
# JWT配置 (必填 - 生产环境必须修改)
# ============================================
# 注意: JWT密钥必须是强随机字符串,长度至少32个字符
# 生成方法: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_at_least_32_characters_long_change_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_at_least_32_characters_long_change_in_production
JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# CORS配置
# ============================================
CORS_ORIGIN=http://localhost:3010

# ============================================
# 文件上传配置
# ============================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=2097152

# ============================================
# TXT 批量上传默认热度配置
# ============================================
# 管理后台批量导入 TXT 时，会自动给新小说生成阅读量/收藏量随机数。
# 如需更贴近实际运营节奏，可在生产 .env 中调整下列范围。
TXT_UPLOAD_RANDOM_VIEWS_MIN=1000
TXT_UPLOAD_RANDOM_VIEWS_MAX=50000
TXT_UPLOAD_RANDOM_COLLECTIONS_MIN=50
TXT_UPLOAD_RANDOM_COLLECTIONS_MAX=3000

# ============================================
# 安全提示
# ============================================
# 1. 永远不要将 .env 文件提交到版本控制系统
# 2. 生产环境必须使用强密码和密钥
# 3. JWT密钥长度至少32个字符
# 4. 定期更换密码和密钥
# 5. 管理员账号密码必须足够复杂



# ============================================
# 激活码加密密钥 (必填，用于会员激活码 AES 加密)
# 注意：admin-backend 与 backend 必须配置完全相同的值，否则两边读不通
# 生成方法：node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# ============================================
ACTIVATION_CODE_SECRET=
